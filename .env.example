# 环境配置文件示例
# 复制此文件为 .env、.env.development、.env.production 等并填入真实配置

# ========== 基础配置 ==========
# 平台本地运行端口号
VITE_PORT = 8848

# 是否隐藏首页
VITE_HIDE_HOME = false

# ========== 路由配置 ==========
# 路由历史模式：hash / h5
VITE_ROUTER_HISTORY = "hash"

# 线上环境平台打包路径
VITE_PUBLIC_PATH = /

# ========== API配置 ==========
# Java后端API地址
VITE_API_BASE_URL = http://localhost:8081

# AI助手地址
VITE_CHAT_URL = http://localhost:3000

# ========== 构建配置 ==========
# 是否在打包时使用cdn替换本地库
VITE_CDN = false

# 是否启用gzip压缩
VITE_COMPRESSION = "none"
